  description="Honest electric bike reviews, expert buying guides, and maintenance tips. Find the perfect e-bike from Burchda, King Bull, and Vivi."
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>

  <!-- START ADVERTISER: Vivi Ebike (US) from awin.com -->
