---
import BaseLayout from '@layouts/BaseLayout.astro';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

// Per-store affiliate links
const AFF_BURCHDA = 'https://www.awin1.com/cread.php?awinmid=123118&awinaffid=2915733';
const AFF_KINGBULL = 'https://www.awin1.com/cread.php?awinmid=124136&awinaffid=2915733';
const AFF_VIVI = 'https://www.awin1.com/cread.php?awinmid=98557&awinaffid=2915733';
// Aliases for templates
const aff1 = AFF_BURCHDA;
const aff2 = AFF_KINGBULL;
const aff3 = AFF_VIVI;

// Separate products from guides
const products = productsData.filter(p => p.price);
const guides = productsData.filter(p => !p.price);

// Featured: top 3 by rating
const featured = products.slice(0, 3);

// Categories for sidebar
const categories = ['All', 'Mountain', 'Commuter', 'Folding', 'Cargo', 'Fat Tire', 'Premium'];
---

