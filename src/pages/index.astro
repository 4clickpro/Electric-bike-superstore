const base = import.meta.env.BASE_URL;

// Awin affiliate links
const aff1 = 'https://www.awin1.com/cread.php?awinmid=123118&awinaffid=2915733';
const aff2 = 'https://www.awin1.com/cread.php?awinmid=124136&awinaffid=2915733';
const aff3 = 'https://www.awin1.com/cread.php?awinmid=98557&awinaffid=2915733';

const featuredPosts = [
  {
    slug: 'shop-ebike-boys-fat-tire-1200w',
    title: 'eBike Boys Fat Tire Electric Bike — 1200W, 30+ MPH',
    excerpt: '1200W motor, fat tires, and 30+ MPH top speed. The ultimate fat tire e-bike for all-terrain domination.',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80',
