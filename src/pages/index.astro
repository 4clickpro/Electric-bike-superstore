---

<BaseLayout
  title="The Electric Bike Superstore — Best Electric Bike Reviews & Buying Guides 2026"
  description="Honest electric bike reviews, expert buying guides, and maintenance tips. Find the perfect e-bike for your commute, trails, or adventure."
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>

  <!-- ===== HERO — Clean, text-focused ===== -->
  <section style="padding: 60px 0 48px; background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div style="max-width: 700px;">
        <h1 style="font-size: 2.4rem; margin-bottom: 16px; font-weight: 800;">
          Best Electric Bike <span class="gradient-text">Reviews & Guides</span>
        </h1>
        <p style="font-size: 1.1rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 32px;">
          Honest, in-depth reviews of the best e-bikes — from commuter and mountain bikes to folding and cargo. Backed by real testing, not marketing hype.
        </p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          <a href={`${base}blog`} class="btn btn-primary">Read Reviews</a>
          <a href={`${base}blog?category=Buying+Guide`} class="btn btn-outline">Buying Guides</a>
          <a href={aff1} target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="border-color: #38a169; color: #38a169;">🛒 Shop E-Bikes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== QUIZ — Green restyled ===== -->
  <section class="section" style="padding: 32px 0; background: var(--color-accent-light); border-bottom: 1px solid var(--color-border);">
    <div class="container" style="max-width: 640px;">
      <div style="text-align: center; margin-bottom: 24px;">
        <span class="badge badge-new" style="margin-bottom: 8px;">Interactive</span>
        <h2 style="font-size: 1.3rem; margin-bottom: 4px; font-weight: 600;">Find Your Perfect E-Bike in 30 Seconds</h2>
        <p style="color: var(--color-text-secondary); font-size: 0.9rem;">Answer 3 quick questions and we'll match you with the ideal ride.</p>
      </div>
      <div class="quiz-widget" id="quiz-widget" style="background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 28px;">
        <div class="quiz-progress" style="width: 100%; height: 4px; background: var(--color-border-light); border-radius: 4px; margin-bottom: 24px; overflow: hidden;">
          <div class="quiz-progress-bar" id="quiz-progress-bar" style="height: 100%; width: 0%; background: var(--color-accent); border-radius: 4px; transition: width 0.4s ease;"></div>
        </div>
        <div class="quiz-step active" data-step="1">
          <h3 style="font-size: 1.1rem; margin-bottom: 16px; text-align: center; font-weight: 600;">What's your primary riding style?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" onclick="quizAnswer(1, 'commuter', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">🏙️ City Commuting</button>
            <button class="quiz-opt" onclick="quizAnswer(1, 'mountain', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">⛰️ Off-Road Trails</button>
            <button class="quiz-opt" onclick="quizAnswer(1, 'folding', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">🎒 Compact & Portable</button>
            <button class="quiz-opt" onclick="quizAnswer(1, 'cargo', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">📦 Hauling & Utility</button>
          </div>
        </div>
        <div class="quiz-step" data-step="2" style="display: none;">
          <h3 style="font-size: 1.1rem; margin-bottom: 16px; text-align: center; font-weight: 600;">What's your budget range?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" onclick="quizAnswer(2, 'budget', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">Under $1,000</button>
            <button class="quiz-opt" onclick="quizAnswer(2, 'mid', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">$1,000 – $2,500</button>
            <button class="quiz-opt" onclick="quizAnswer(2, 'premium', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">$2,500+</button>
          </div>
        </div>
        <div class="quiz-step" data-step="3" style="display: none;">
          <h3 style="font-size: 1.1rem; margin-bottom: 16px; text-align: center; font-weight: 600;">How far do you need to ride per charge?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" onclick="quizAnswer(3, 'short', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">Under 30 miles</button>
            <button class="quiz-opt" onclick="quizAnswer(3, 'medium', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">30–60 miles</button>
            <button class="quiz-opt" onclick="quizAnswer(3, 'long', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">60+ miles</button>
          </div>
        </div>
        <div class="quiz-step" data-step="4" style="display: none; text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 12px;" id="quiz-result-emoji">🎉</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 8px; font-weight: 700;" id="quiz-result-title">Your Perfect Match!</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: 20px;" id="quiz-result-desc"></p>
          <a class="btn btn-primary" id="quiz-result-link" href={aff2} target="_blank" rel="noopener noreferrer">Shop Your Match →</a>
          <button style="display: block; margin: 16px auto 0; background: none; border: none; color: var(--color-text-muted); font-size: 0.82rem; cursor: pointer; text-decoration: underline;" onclick="quizReset()">↻ Retake Quiz</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAIN 2-COLUMN LAYOUT ===== -->
  <section class="section" style="padding-top: 32px;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 300px; gap: 40px; align-items: start;">

        <!-- CENTER CONTENT -->
        <main>
          <!-- Featured Posts -->
          <div style="margin-bottom: 48px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 2px solid var(--color-accent);">
              <h2 style="font-size: 1.3rem; margin: 0; font-weight: 700;">Featured Reviews</h2>
              <a href={`${base}blog`} style="font-size: 0.85rem; color: var(--color-accent); font-weight: 600;">View All →</a>
            </div>
            <div class="grid-2">
              {featuredPosts.map(post => <BlogCard {...post} />)}
            </div>
          </div>

          <!-- Latest Reviews -->
          <div style="margin-bottom: 48px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 2px solid var(--color-border);">
              <h2 style="font-size: 1.3rem; margin: 0; font-weight: 700;">Latest Reviews</h2>
            </div>
            <div class="grid-2">
              {latestReviews.map(post => <BlogCard {...post} />)}
            </div>
          </div>
        </main>

        <!-- RIGHT SIDEBAR -->
        <aside style="position: sticky; top: 96px;">
          <!-- Browse By Type -->
          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; margin-bottom: 20px;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 700;">Browse By Type</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                {['Commuter', 'Mountain', 'Folding', 'Fat Tire', 'Cargo', 'Scooters'].map((type) => (
                  <li style="margin-bottom: 2px;">
                    <a href={`${base}blog?category=${type}`} style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light); transition: color 150ms;">{type} E-Bikes</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>

          <!-- Quick Links -->
          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; margin-bottom: 20px;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 700;">Quick Links</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                <li><a href={aff1} target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-accent); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">🛒 Shop All E-Bikes</a></li>
                <li><a href={aff2} target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-accent); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">💰 Best Under $1,000</a></li>
                <li><a href={aff3} target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-accent); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">🏆 Premium Picks</a></li>
                <li><a href={`${base}blog?category=Buying+Guide`} style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500;">📖 Buying Guides</a></li>
              </ul>
            </nav>
          </div>

          <!-- Newsletter -->
          <div style="background: var(--color-accent); border-radius: var(--radius-md); padding: 24px; color: #fff;">
            <h3 style="font-size: 0.95rem; margin-bottom: 6px; font-weight: 700; color: #fff;">E-Bike Deals Newsletter</h3>
            <p style="font-size: 0.82rem; color: rgba(255,255,255,0.85); margin-bottom: 14px; line-height: 1.5;">Get weekly deals, new model alerts, and expert riding tips.</p>
            <form onsubmit="event.preventDefault(); alert('Thanks for subscribing!');" style="display: flex; flex-direction: column; gap: 8px;">
              <input type="email" placeholder="your@email.com" required aria-label="Email" style="padding: 10px 14px; border-radius: var(--radius-sm); border: none; font-size: 0.88rem; font-family: var(--font-sans);" />
              <button type="submit" class="btn" style="background: #fff; color: var(--color-accent); justify-content: center; font-weight: 700;">Subscribe</button>
            </form>
            <p style="font-size: 0.72rem; color: rgba(255,255,255,0.7); margin-top: 10px;">No spam. Unsubscribe anytime.</p>
          </div>
        </aside>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  var quizState = { q1: null, q2: null, q3: null };
  window.quizAnswer = function(step, value, btn) {
    quizState['q' + step] = value;
    var parent = btn.parentElement;
    parent.querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); b.style.borderColor = 'var(--color-border)'; b.style.background = '#fff'; });
    btn.classList.add('selected');
    btn.style.borderColor = 'var(--color-accent)';
    btn.style.background = 'var(--color-accent-light)';
    document.getElementById('quiz-progress-bar').style.width = (step / 3 * 100) + '%';
    setTimeout(function() {
      document.querySelectorAll('.quiz-step[data-step="' + step + '"]')[0].style.display = 'none';
      document.querySelectorAll('.quiz-step[data-step="' + (step + 1) + '"]')[0].style.display = 'block';
      document.querySelector('.quiz-step[data-step="' + (step + 1) + '"]').classList.add('active');
      if (step === 3) {
        var q1 = quizState.q1;
        var map = {
          commuter: { emoji: '🏙️', title: 'The Urban Commuter', desc: 'You need a sleek, reliable e-bike that makes city riding effortless. Integrated lights, fenders, and racks — your daily commute just got an upgrade.' },
          mountain: { emoji: '⛰️', title: 'The Trail Blazer', desc: 'You live for off-road adventure. Our mountain e-bikes feature full suspension, fat tires, and powerful motors for any terrain.' },
          folding: { emoji: '🎒', title: 'The City Minimalist', desc: 'Portability is everything. Our folding e-bikes pack down small, ride big, and are perfect for mixed commutes.' },
          cargo: { emoji: '📦', title: 'The Family Hauler', desc: 'You need to move people and stuff. Our cargo e-bikes have the power, range, and carrying capacity for local trips.' }
        };
        var r = map[q1] || map.commuter;
        document.getElementById('quiz-result-emoji').textContent = r.emoji;
        document.getElementById('quiz-result-title').textContent = r.title;
        document.getElementById('quiz-result-desc').textContent = r.desc;
      }
    }, 300);
  };
  window.quizReset = function() {
    quizState = { q1: null, q2: null, q3: null };
    document.querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); b.style.borderColor = 'var(--color-border)'; b.style.background = '#fff'; });
    document.querySelectorAll('.quiz-step').forEach(function(s) { s.style.display = 'none'; s.classList.remove('active'); });
    document.querySelector('.quiz-step[data-step="1"]').style.display = 'block';
    document.querySelector('.quiz-step[data-step="1"]').classList.add('active');
    document.getElementById('quiz-progress-bar').style.width = '0%';
  };
</script>

<style>
  .quiz-opt:hover {
    border-color: var(--color-accent) !important;
    background: var(--color-accent-light) !important;
  }

  @media (max-width: 1024px) {
    .container > div[style*="grid-template-columns: 1fr 300px"] {
      grid-template-columns: 1fr !important;
    }
    aside[style*="position: sticky"] {
      position: static !important;
    }
  }

  @media (max-width: 768px) {
    div[style*="grid-template-columns: repeat(4, 1fr)"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
