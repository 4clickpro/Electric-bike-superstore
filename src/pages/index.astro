  },
  {
    slug: 'shop-aniioki-a9-pro-max',
    title: 'Aniioki A9 Pro Max — 60V Dual Motor eBike',
    excerpt: 'Dual 60V motors for unstoppable power. The Aniioki A9 Pro Max is the ultimate high-performance e-bike.',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80',
    category: 'Premium',
    date: '2027-01-13',
    readTime: '5',
  },
  {
    slug: 'ebike-commuting-save-time-money',
    title: 'How E-Bike Commuting Saves You Time & Money (With Real Numbers)',
    excerpt: 'We crunched the numbers. A $1,899 e-bike pays for itself in 8 months compared to driving.',
    image: 'https://images.unsplash.com/photo-1559348349-86f1f65817fe?w=800&q=80',
    category: 'Commuting',
    date: '2027-01-08',
