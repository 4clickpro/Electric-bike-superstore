---
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import ProductCard from '@components/ProductCard.astro';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

const featuredPosts = [
  {
    slug: 'how-to-choose-your-first-electric-bike',
    title: 'How to Choose Your First Electric Bike: The Complete Guide',
    excerpt: 'Everything you need to know before buying your first e-bike — motor types, battery range, classes, and the questions most first-time buyers forget to ask.',
    image: 'https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=800&q=80',
    category: 'Buying Guide',
    date: '2025-04-15',
    readTime: '10',
  },
  {
    slug: 'ebike-commuting-save-time-money',
    title: 'How E-Bike Commuting Saves You Time & Money (With Real Numbers)',
    excerpt: 'We crunched the numbers. A $1,899 e-bike pays for itself in 8 months compared to driving.',
    image: 'https://images.unsplash.com/photo-1559348349-86f1f65817fe?w=800&q=80',
    category: 'Commuting',
    date: '2025-03-22',
    readTime: '7',
  },
  {
    slug: 'ebike-maintenance-checklist',
    title: 'E-Bike Maintenance Checklist: Keep Your Ride Running Like New',
    excerpt: 'From battery care to chain lube, brake adjustments to tire pressure — this routine will extend your e-bike\'s lifespan.',
    image: 'https://images.unsplash.com/photo-1532298229144-0ec0c57515c7?w=800&q=80',
    category: 'Maintenance',
    date: '2025-02-10',
    readTime: '8',
  },
];

const featuredProducts = productsData.filter((p: any) => p.featured).slice(0, 4);
---

<BaseLayout
  title="The Electric Bike Superstore — Best Electric Bikes 2026 | Commuter, Mountain, Folding & Cargo E-Bikes"
  description="Discover top-rated electric bikes, expert buying guides, and essential e-bike gear. Free shipping on orders over $75. 30-day returns."
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>

  <!-- ===== HERO — Clean, text-focused ===== -->
  <section style="padding: 40px 0 32px; background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div style="max-width: 700px;">
        <h1 style="font-size: 2rem; margin-bottom: 12px; font-weight: 800;">
          Find the Right Electric Bike for You
        </h1>
        <p style="font-size: 1.05rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 24px;">
          Honest reviews, expert buying guides, and a curated selection of the best e-bikes — from commuters to mountain bikes.
        </p>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Browse E-Bikes
          </a>
          <a href="#guides" class="btn btn-outline">Read the Guides</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== QUIZ — Keep this, it's good UX ===== -->
  <section class="section" style="padding: 32px 0; background: var(--color-accent-light); border-bottom: 1px solid var(--color-border);">
    <div class="container" style="max-width: 640px;">
      <div style="text-align: center; margin-bottom: 24px;">
        <span class="badge badge-new" style="margin-bottom: 8px;">Interactive</span>
        <h2 style="font-size: 1.3rem; margin-bottom: 4px;">Find Your Perfect E-Bike in 30 Seconds</h2>
        <p style="color: var(--color-text-secondary); font-size: 0.9rem;">Answer 3 quick questions and we'll match you with the ideal ride.</p>
      </div>
      <div class="quiz-widget" id="quiz-widget" style="background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 28px;">
        <div class="quiz-progress" style="width: 100%; height: 4px; background: var(--color-border-light); border-radius: 4px; margin-bottom: 24px; overflow: hidden;">
          <div class="quiz-progress-bar" id="quiz-progress-bar" style="height: 100%; width: 0%; background: var(--color-accent); border-radius: 4px; transition: width 0.4s ease;"></div>
        </div>
        <div class="quiz-step active" data-step="1">
          <h3 style="font-size: 1.1rem; margin-bottom: 16px; text-align: center; font-weight: 600;">What's your primary riding style?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" data-q1="commuter" onclick="quizAnswer(1, 'commuter', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">🏙️ City Commuting</button>
            <button class="quiz-opt" data-q1="mountain" onclick="quizAnswer(1, 'mountain', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">⛰️ Off-Road Trails</button>
            <button class="quiz-opt" data-q1="folding" onclick="quizAnswer(1, 'folding', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">🎒 Compact & Portable</button>
            <button class="quiz-opt" data-q1="cargo" onclick="quizAnswer(1, 'cargo', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">📦 Hauling Cargo</button>
          </div>
        </div>
        <div class="quiz-step" data-step="2" style="display: none;">
          <h3 style="font-size: 1.1rem; margin-bottom: 16px; text-align: center; font-weight: 600;">What's your budget range?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" data-q2="budget" onclick="quizAnswer(2, 'budget', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">Under $1,000</button>
            <button class="quiz-opt" data-q2="mid" onclick="quizAnswer(2, 'mid', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">$1,000 – $2,500</button>
            <button class="quiz-opt" data-q2="premium" onclick="quizAnswer(2, 'premium', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">$2,500+</button>
          </div>
        </div>
        <div class="quiz-step" data-step="3" style="display: none;">
          <h3 style="font-size: 1.1rem; margin-bottom: 16px; text-align: center; font-weight: 600;">How far do you need to ride per charge?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" data-q3="short" onclick="quizAnswer(3, 'short', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">Under 30 miles</button>
            <button class="quiz-opt" data-q3="medium" onclick="quizAnswer(3, 'medium', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">30–60 miles</button>
            <button class="quiz-opt" data-q3="long" onclick="quizAnswer(3, 'long', this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">60+ miles</button>
          </div>
        </div>
        <div class="quiz-step" data-step="4" style="display: none; text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 12px;" id="quiz-result-emoji">🎉</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 8px; font-weight: 700;" id="quiz-result-title">Your Perfect Match!</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: 20px;" id="quiz-result-desc"></p>
          <a class="btn btn-primary" id="quiz-result-link" href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer">Shop Your Match →</a>
          <button style="display: block; margin: 16px auto 0; background: none; border: none; color: var(--color-text-muted); font-size: 0.82rem; cursor: pointer; text-decoration: underline;" onclick="quizReset()">↻ Retake Quiz</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAIN 3-COLUMN LAYOUT ===== -->
  <section class="section" style="padding-top: 32px;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 220px 1fr 280px; gap: 32px; align-items: start;">

        <!-- LEFT SIDEBAR: Categories + Quick Links -->
        <aside style="position: sticky; top: 20px;">
          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; margin-bottom: 20px;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 700;">Browse By Type</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Commuter E-Bikes</a></li>
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Mountain E-Bikes</a></li>
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Folding E-Bikes</a></li>
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Cargo E-Bikes</a></li>
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Fat Tire E-Bikes</a></li>
                <li><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500;">Electric Scooters</a></li>
              </ul>
            </nav>
          </div>

          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 700;">Best By Budget</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Best Under $1,000</a></li>
                <li style="margin-bottom: 2px;"><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">Best $1,000–$2,000</a></li>
                <li><a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="display: block; padding: 8px 0; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500;">Premium $2,000+</a></li>
              </ul>
            </nav>
          </div>
        </aside>

        <!-- CENTER: Products + Featured -->
        <main>
          <!-- Category Cards -->
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 40px;">
            {[
              { label: 'Commuter', icon: '🏙️', slug: 'commuter-pro-500' },
              { label: 'Mountain', icon: '⛰️', slug: 'trail-blazer-elite' },
              { label: 'Folding', icon: '🎒', slug: 'fold-commute-x1' },
              { label: 'Cargo', icon: '📦', slug: 'cargo-hauler-pro' },
            ].map(cat => (
              <a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" class="card" style="padding: 20px 12px; text-align: center; text-decoration: none;">
                <span style="font-size: 1.8rem; display: block; margin-bottom: 8px;">{cat.icon}</span>
                <span style="font-size: 0.88rem; font-weight: 600; color: var(--color-text-primary);">{cat.label} E-Bikes</span>
              </a>
            ))}
          </div>

          <!-- Featured Products Section -->
          <div style="margin-bottom: 40px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid var(--color-accent);">
              <h2 style="font-size: 1.3rem; margin: 0; font-weight: 700;">Featured E-Bikes</h2>
              <a href="https://hnrqqt-an.myshopify.com/collections/all" target="_blank" rel="noopener noreferrer" style="font-size: 0.85rem; color: var(--color-accent); font-weight: 600;">View All →</a>
            </div>
            <div class="grid-2">
              {featuredProducts.map((product: any) => <ProductCard {...product} />)}
            </div>
          </div>

          <!-- Promo Banner — Kept but restyled -->
          <div style="margin-bottom: 40px; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
            <div style="display: grid; grid-template-columns: 200px 1fr;">
              <div style="background: var(--color-bg-elevated); overflow: hidden;">
                <img
                  src="/images/aovopro-bk520.jpg"
                  alt="AOVOPRO BK520 Electric MTB"
                  width="200"
                  height="200"
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
              <div style="padding: 24px;">
                <span class="badge badge-sale" style="margin-bottom: 8px;">Featured Deal</span>
                <h3 style="font-size: 1.15rem; margin-bottom: 8px; font-weight: 700;">AOVOPRO BK520 Electric MTB</h3>
                <p style="color: var(--color-text-secondary); font-size: 0.88rem; margin-bottom: 16px; line-height: 1.6;">
                  350W brushless motor, 48V 5.2Ah battery, Smart App control, 7-speed Shimano. Up to 40 miles range.
                </p>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                  <span style="font-size: 0.82rem; color: var(--color-text-muted); text-decoration: line-through;">$698.00</span>
                  <span style="font-size: 1.5rem; font-weight: 800; color: var(--color-accent);">$349.00</span>
                </div>
                <a href="https://www.aovopro.com/?wpam_id=1120" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">View Deal →</a>
              </div>
            </div>
          </div>

          <!-- Staff Pick — Aventon Level 3 -->
          <div style="margin-bottom: 40px; border: 2px solid var(--color-accent); border-radius: var(--radius-md); overflow: hidden;">
            <a href="https://hnrqqt-an.myshopify.com/cart/53423858581870:1" target="_blank" rel="noopener noreferrer" style="display: grid; grid-template-columns: 240px 1fr; text-decoration: none; color: inherit;">
              <div style="background: var(--color-bg-elevated);">
                <img
                  src="/images/aventon-level3-step-through.jpg"
                  alt="Aventon Level.3 Commuter E-Bike"
                  width="240"
                  height="240"
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
              <div style="padding: 24px;">
                <span class="badge badge-featured" style="margin-bottom: 10px;">⭐ Staff Pick</span>
                <h3 style="font-size: 1.2rem; margin-bottom: 8px; font-weight: 700;">Aventon Level.3 Step-Through Commuter E-Bike</h3>
                <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 10px;">
                  {[1,2,3,4,5].map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#d69e2e" stroke="#d69e2e" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                  <span style="font-size: 0.82rem; color: var(--color-text-muted); margin-left: 4px;">4.8 / 5</span>
                </div>
                <p style="color: var(--color-text-secondary); font-size: 0.88rem; margin-bottom: 14px; line-height: 1.6;">
                  GPS tracking, front suspension, rear rack & fenders included. Up to 60 miles range. Step-through design for easy mounting.
                </p>
                <div style="display: flex; align-items: baseline; gap: 10px;">
                  <span style="font-size: 1.5rem; font-weight: 800; color: var(--color-accent);">$1,699</span>
                  <span style="font-size: 0.82rem; color: var(--color-text-muted); text-decoration: line-through;">$1,899</span>
                </div>
              </div>
            </a>
          </div>
        </main>

        <!-- RIGHT SIDEBAR: Blog Posts + Guides -->
        <aside style="position: sticky; top: 20px;">
          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; margin-bottom: 20px;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 700;">Latest Buying Guides</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                {featuredPosts.map((post, i) => (
                  <li style={`padding: ${i < featuredPosts.length - 1 ? '10px 0' : '10px 0 0'}; ${i < featuredPosts.length - 1 ? 'border-bottom: 1px solid var(--color-border-light);' : ''}`}>
                    <a href={`https://hnrqqt-an.myshopify.com/blogs/news/${post.slug}`} target="_blank" rel="noopener noreferrer" style="font-size: 0.88rem; color: var(--color-text-primary); font-weight: 600; line-height: 1.4; display: block;">{post.title}</a>
                    <span style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 4px; display: block;">{post.category} · {post.readTime} min read</span>
                  </li>
                ))}
              </ul>
            </nav>
          </div>

          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; margin-bottom: 20px;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 12px; font-weight: 700;">Why Shop With Us</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              <li style="display: flex; align-items: flex-start; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--color-border-light);">
                <span style="flex-shrink: 0; margin-top: 2px;">🚚</span>
                <div>
                  <strong style="font-size: 0.85rem; display: block;">Free Shipping</strong>
                  <span style="font-size: 0.78rem; color: var(--color-text-muted);">On orders over $75</span>
                </div>
              </li>
              <li style="display: flex; align-items: flex-start; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--color-border-light);">
                <span style="flex-shrink: 0; margin-top: 2px;">🔄</span>
                <div>
                  <strong style="font-size: 0.85rem; display: block;">30-Day Returns</strong>
                  <span style="font-size: 0.78rem; color: var(--color-text-muted);">No questions asked</span>
                </div>
              </li>
              <li style="display: flex; align-items: flex-start; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--color-border-light);">
                <span style="flex-shrink: 0; margin-top: 2px;">🛡️</span>
                <div>
                  <strong style="font-size: 0.85rem; display: block;">2-Year Warranty</strong>
                  <span style="font-size: 0.78rem; color: var(--color-text-muted);">Frame, motor, battery</span>
                </div>
              </li>
              <li style="display: flex; align-items: flex-start; gap: 8px; padding: 8px 0 0;">
                <span style="flex-shrink: 0; margin-top: 2px;">📞</span>
                <div>
                  <strong style="font-size: 0.85rem; display: block;">Expert Support</strong>
                  <span style="font-size: 0.78rem; color: var(--color-text-muted);">7 days a week</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Newsletter -->
          <div style="background: var(--color-accent); border-radius: var(--radius-md); padding: 24px; color: #fff;">
            <h3 style="font-size: 0.95rem; margin-bottom: 6px; font-weight: 700; color: #fff;">E-Bike Deals Newsletter</h3>
            <p style="font-size: 0.82rem; color: rgba(255,255,255,0.85); margin-bottom: 14px; line-height: 1.5;">Get weekly deals, new model alerts, and expert riding tips.</p>
            <form onsubmit="event.preventDefault(); alert('Thanks for subscribing!');" style="display: flex; flex-direction: column; gap: 8px;">
              <input type="email" placeholder="your@email.com" required aria-label="Email" style="padding: 10px 14px; border-radius: var(--radius-sm); border: none; font-size: 0.88rem; font-family: var(--font-sans);" />
              <button type="submit" class="btn" style="background: #fff; color: var(--color-accent); justify-content: center; font-weight: 700;">Subscribe</button>
            </form>
            <p style="font-size: 0.72rem; color: rgba(255,255,255,0.7); margin-top: 10px;">No spam. Unsubscribe anytime.</p>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ===== GUIDES SECTION ===== -->
  <section id="guides" class="section" style="background: var(--color-bg-elevated); border-top: 1px solid var(--color-border);">
    <div class="container" style="max-width: 900px;">
      <div style="text-align: center; margin-bottom: 32px;">
        <h2 style="font-size: 1.5rem; margin-bottom: 8px; font-weight: 700;">Expert E-Bike Guides</h2>
        <p style="color: var(--color-text-secondary); font-size: 0.95rem;">Buying advice and maintenance tips to help you get the most from your e-bike.</p>
      </div>
      <div class="grid-3">
        {featuredPosts.map(post => <BlogCard {...post} />)}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Quiz logic
  var quizState = { q1: null, q2: null, q3: null };
  window.quizAnswer = function(step, value, btn) {
    quizState['q' + step] = value;
    var parent = btn.parentElement;
    parent.querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); b.style.borderColor = 'var(--color-border)'; b.style.background = '#fff'; });
    btn.classList.add('selected');
    btn.style.borderColor = 'var(--color-accent)';
    btn.style.background = 'var(--color-accent-light)';
    document.getElementById('quiz-progress-bar').style.width = (step / 3 * 100) + '%';
    setTimeout(function() {
      document.querySelectorAll('.quiz-step[data-step="' + step + '"]')[0].style.display = 'none';
      document.querySelectorAll('.quiz-step[data-step="' + (step + 1) + '"]')[0].style.display = 'block';
      document.querySelector('.quiz-step[data-step="' + (step + 1) + '"]').classList.add('active');
      if (step === 3) {
        var q1 = quizState.q1;
        var map = {
          commuter: { emoji: '🏙️', title: 'The Urban Commuter', desc: 'You need a sleek, reliable e-bike that makes city riding effortless. Integrated lights, fenders, and racks — your daily commute just got an upgrade.' },
          mountain: { emoji: '⛰️', title: 'The Trail Blazer', desc: 'You live for off-road adventure. Our mountain e-bikes feature full suspension, fat tires, and powerful motors for any terrain.' },
          folding: { emoji: '🎒', title: 'The City Minimalist', desc: 'Portability is everything. Our folding e-bikes pack down small, ride big, and are perfect for mixed commutes.' },
          cargo: { emoji: '📦', title: 'The Family Hauler', desc: 'You need to move people and stuff. Our cargo e-bikes have the power, range, and carrying capacity for local trips.' }
        };
        var r = map[q1] || map.commuter;
        document.getElementById('quiz-result-emoji').textContent = r.emoji;
        document.getElementById('quiz-result-title').textContent = r.title;
        document.getElementById('quiz-result-desc').textContent = r.desc;
      }
    }, 300);
  };
  window.quizReset = function() {
    quizState = { q1: null, q2: null, q3: null };
    document.querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); b.style.borderColor = 'var(--color-border)'; b.style.background = '#fff'; });
    document.querySelectorAll('.quiz-step').forEach(function(s) { s.style.display = 'none'; s.classList.remove('active'); });
    document.querySelector('.quiz-step[data-step="1"]').style.display = 'block';
    document.querySelector('.quiz-step[data-step="1"]').classList.add('active');
    document.getElementById('quiz-progress-bar').style.width = '0%';
  };
</script>

<style>
  .quiz-opt:hover {
    border-color: var(--color-accent) !important;
    background: var(--color-accent-light) !important;
  }

  @media (max-width: 1024px) {
    .container > div[style*="grid-template-columns: 220px 1fr 280px"] {
      grid-template-columns: 200px 1fr !important;
    }
    .container > div[style*="grid-template-columns: 220px 1fr 280px"] > aside:last-child {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .container > div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
    aside[style*="position: sticky"] {
      position: static !important;
    }
    div[style*="grid-template-columns: repeat(4, 1fr)"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    div[style*="grid-template-columns: 200px 1fr"],
    div[style*="grid-template-columns: 240px 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
