const latestReviews = [
  {
    slug: 'shop-terrosor-715w-folding',
    title: 'Terrosor 715W Peak Folding Electric Bicycle',
    excerpt: '715W peak power in a folding frame. Max speed 50km/h. Commute or adventure — this bike does both.',
    image: 'https://images.unsplash.com/photo-1532298229144-0ec0c57515c7?w=800&q=80',
    category: 'Folding',
