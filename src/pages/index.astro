---
import BaseLayout from '@layouts/BaseLayout.astro';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

// Per-store affiliate links
const AFF_BURCHDA = 'https://www.awin1.com/cread.php?awinmid=123118&awinaffid=2915733';
const AFF_KINGBULL = 'https://www.awin1.com/cread.php?awinmid=124136&awinaffid=2915733';
const AFF_VIVI = 'https://www.awin1.com/cread.php?awinmid=98557&awinaffid=2915733';
// Aliases for templates
const aff1 = AFF_BURCHDA;
const aff2 = AFF_KINGBULL;
const aff3 = AFF_VIVI;

// Separate products from guides
const products = productsData.filter(p => p.price);
const guides = productsData.filter(p => !p.price);

// Featured: top 3 by rating
const featured = products.slice(0, 3);

// Categories for sidebar
const categories = ['All', 'Mountain', 'Commuter', 'Folding', 'Cargo', 'Fat Tire', 'Premium'];
---

<BaseLayout
  title="The Electric Bike Superstore — Best Electric Bike Reviews & Buying Guides 2026"
  description="Honest electric bike reviews, expert buying guides, and maintenance tips. Find the perfect e-bike from Burchda, King Bull, and Vivi."
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>

  <!-- START ADVERTISER: Vivi Ebike (US) from awin.com -->
  <div style="text-align: center; padding: 12px 20px; background: var(--color-bg); border-bottom: 1px solid var(--color-border);">
    <a rel="sponsored" href="https://www.awin1.com/cread.php?s=3682927&v=98557&q=494573&r=2915733" target="_blank" rel="noopener noreferrer">
      <img src="https://www.awin1.com/cshow.php?s=3682927&v=98557&q=494573&r=2915733" border="0" alt="Vivi Ebike (US)" style="max-width: 100%; height: auto;">
    </a>
  </div>
  <!-- END ADVERTISER: Vivi Ebike (US) from awin.com -->

  <!-- ===== HERO — Clean, text-focused ===== -->
  <section style="padding: 48px 0 40px; background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div style="max-width: 700px;">
        <h1 style="font-size: 2.2rem; margin-bottom: 12px; font-weight: 800;">
          Best Electric Bike <span class="gradient-text">Reviews & Buying Guides</span>
        </h1>
        <p style="font-size: 1.05rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 28px;">
          Honest, in-depth reviews of the best e-bikes from Burchda, King Bull, and Vivi. Real specs, real prices, real testing — not marketing hype.
        </p>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href={`${base}blog`} class="btn btn-primary">Read Reviews</a>
          <a href={`${base}blog?category=Buying+Guide`} class="btn btn-outline">Buying Guides</a>
          <a href={aff1} target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="border-color: #38a169; color: #38a169;">🛒 Shop E-Bikes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAIN 2-COLUMN LAYOUT ===== -->
  <section class="section" style="padding-top: 32px;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 280px; gap: 40px; align-items: start;">

        <!-- CENTER: EBR-Style Product Reviews -->
        <main>
          <div style="margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid var(--color-accent);">
            <h2 style="font-size: 1.3rem; margin: 0; font-weight: 700;">Best Electric Bikes We've Tested</h2>
            <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-top: 4px;">Updated June 2026 — Prices and availability subject to change</p>
          </div>

          {products.map(product => (
            <article class="bike-review" style="margin-bottom: 40px; padding-bottom: 40px; border-bottom: 1px solid var(--color-border);">
              <!-- Product Header -->
              <div style="display: grid; grid-template-columns: 200px 1fr; gap: 24px; margin-bottom: 16px;">
                <a href={`${base}blog/${product.slug}/`} style="display: block; border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--color-border);">
                  <img src={product.image} alt={product.title} loading="lazy" style="width: 100%; aspect-ratio: 4/3; object-fit: cover;" />
                </a>
                <div>
                  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                    <span class="badge badge-new">{product.category}</span>
                    <span style="font-size: 0.78rem; color: var(--color-text-muted);">{product.store}</span>
                  </div>
                  <h3 style="font-size: 1.15rem; margin-bottom: 6px; font-weight: 700; line-height: 1.3;">
                    <a href={`${base}blog/${product.slug}/`} style="color: var(--color-text-primary); text-decoration: none;">
                      {product.title}
                    </a>
                  </h3>
                  <!-- Star Rating -->
                  <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
                    <div style="display: flex; gap: 1px;">
                      {[1,2,3,4,5].map(i => (
                        <svg width="14" height="14" viewBox="0 0 24 24" fill={i <= Math.round(product.rating) ? "#d69e2e" : "#e1e5e9"} stroke="#d69e2e" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      ))}
                    </div>
                    <span style="font-size: 0.82rem; color: var(--color-text-muted);">{product.rating}/5 ({product.reviews} reviews)</span>
                  </div>
                  <!-- Price -->
                  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 10px;">
                    {product.oldPrice && <span style="font-size: 0.88rem; color: var(--color-text-muted); text-decoration: line-through;">{product.oldPrice}</span>}
                    <span style="font-size: 1.3rem; font-weight: 800; color: var(--color-accent);">{product.price}</span>
                  </div>
                  <!-- CTA -->
                  <a href={product.affiliateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
                    Best Price at {product.store} →
                  </a>
                </div>
              </div>

              <!-- Specs Table -->
              <div style="background: var(--color-bg-elevated); border-radius: var(--radius-md); padding: 16px; margin-bottom: 16px;">
                <h4 style="font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 10px; font-weight: 700;">Key Specs</h4>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px 16px;">
                  {Object.entries(product.specs).slice(0, 6).map(([key, value]) => (
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                      <span style="color: var(--color-text-muted);">{key}:</span>
                      <span style="font-weight: 600; color: var(--color-text-primary);">{value}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Excerpt -->
              <p style="color: var(--color-text-secondary); font-size: 0.92rem; line-height: 1.7; margin-bottom: 12px;">
                {product.excerpt}
              </p>

              <!-- Pros/Cons -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                <div>
                  <h4 style="font-size: 0.82rem; color: var(--color-success); font-weight: 700; margin-bottom: 6px;">👍 PROS</h4>
                  <ul style="list-style: none; padding: 0; margin: 0;">
                    {product.pros.map(pro => (
                      <li style="font-size: 0.82rem; color: var(--color-text-secondary); padding: 3px 0; border-bottom: 1px solid var(--color-border-light);">✓ {pro}</li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 style="font-size: 0.82rem; color: var(--color-danger); font-weight: 700; margin-bottom: 6px;">👎 CONS</h4>
                  <ul style="list-style: none; padding: 0; margin: 0;">
                    {product.cons.map(con => (
                      <li style="font-size: 0.82rem; color: var(--color-text-secondary); padding: 3px 0; border-bottom: 1px solid var(--color-border-light);">✗ {con}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Bottom CTA -->
              <div style="display: flex; gap: 10px; align-items: center;">
                <a href={product.affiliateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                  Check Price at {product.store} →
                </a>
                <a href={`${base}blog/${product.slug}/`} class="btn btn-outline btn-sm">
                  Read Full Review
                </a>
              </div>
            </article>
          ))}

          <!-- Guides Section -->
          <div style="margin-top: 48px;">
            <div style="margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid var(--color-border);">
              <h2 style="font-size: 1.3rem; margin: 0; font-weight: 700;">Expert Buying Guides</h2>
            </div>
            <div class="grid-2">
              {guides.map(guide => (
                <article class="card" style="padding: 20px;">
                  <span class="badge badge-new" style="margin-bottom: 8px;">{guide.category}</span>
                  <h3 style="font-size: 1.05rem; margin-bottom: 8px; font-weight: 700;">
                    <a href={`${base}blog/${guide.slug}/`} style="color: var(--color-text-primary);">{guide.title}</a>
                  </h3>
                  <p style="color: var(--color-text-secondary); font-size: 0.88rem; line-height: 1.6;">{guide.excerpt}</p>
                  <a href={`${base}blog/${guide.slug}/`} class="read-more" style="margin-top: 12px; display: inline-flex;">
                    Read Guide →
                  </a>
                </article>
              ))}
            </div>
          </div>
        </main>

        <!-- RIGHT SIDEBAR -->
        <aside style="position: sticky; top: 96px;">
          <!-- Browse By Type -->
          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 18px; margin-bottom: 16px;">
            <h3 style="font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 10px; font-weight: 700;">Browse By Type</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                {categories.filter(c => c !== 'All').map(cat => (
                  <li>
                    <a href={`${base}blog?category=${cat}`} style="display: block; padding: 7px 0; color: var(--color-text-primary); font-size: 0.88rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light); transition: color 150ms;">{cat} E-Bikes</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>

          <!-- Affiliate Stores -->
          <div style="background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 18px; margin-bottom: 16px;">
            <h3 style="font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); margin-bottom: 10px; font-weight: 700;">Shop By Store</h3>
            <nav>
              <ul style="list-style: none; padding: 0; margin: 0;">
                <li><a href={AFF_BURCHDA} target="_blank" rel="noopener noreferrer" style="display: block; padding: 7px 0; color: var(--color-accent); font-size: 0.88rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">🏪 Burchda Bikes</a></li>
                <li><a href={AFF_KINGBULL} target="_blank" rel="noopener noreferrer" style="display: block; padding: 7px 0; color: var(--color-accent); font-size: 0.88rem; font-weight: 500; border-bottom: 1px solid var(--color-border-light);">🏪 King Bull Bike</a></li>
                <li><a href={AFF_VIVI} target="_blank" rel="noopener noreferrer" style="display: block; padding: 7px 0; color: var(--color-accent); font-size: 0.88rem; font-weight: 500;">🏪 Vivi Bikes</a></li>
              </ul>
            </nav>
          </div>

          <!-- Newsletter -->
          <div style="background: var(--color-accent); border-radius: var(--radius-md); padding: 20px; color: #fff;">
            <h3 style="font-size: 0.9rem; margin-bottom: 4px; font-weight: 700; color: #fff;">E-Bike Deals Newsletter</h3>
            <p style="font-size: 0.78rem; color: rgba(255,255,255,0.85); margin-bottom: 12px; line-height: 1.5;">Get weekly deals, new model alerts, and expert riding tips.</p>
            <form onsubmit="event.preventDefault(); alert('Thanks for subscribing!');" style="display: flex; flex-direction: column; gap: 6px;">
              <input type="email" placeholder="your@email.com" required aria-label="Email" style="padding: 8px 12px; border-radius: var(--radius-sm); border: none; font-size: 0.85rem; font-family: var(--font-sans);" />
              <button type="submit" class="btn" style="background: #fff; color: var(--color-accent); justify-content: center; font-weight: 700; font-size: 0.85rem;">Subscribe</button>
            </form>
            <p style="font-size: 0.68rem; color: rgba(255,255,255,0.7); margin-top: 8px;">No spam. Unsubscribe anytime.</p>
          </div>

          <!-- Disclaimer -->
          <p style="font-size: 0.72rem; color: var(--color-text-muted); margin-top: 12px; line-height: 1.5;">
            <em>As an affiliate partner of Burchda, King Bull, and Vivi, we may earn a small commission on qualifying purchases. This does not affect our reviews or recommendations.</em>
          </p>
        </aside>

      </div>
    </div>
  </section>

  <!-- ===== QUIZ — Bottom of page ===== -->
  <section style="padding: 48px 0; background: var(--color-accent-light); border-top: 2px solid var(--color-accent); margin-top: 48px;">
    <div class="container" style="max-width: 640px;">
      <div style="text-align: center; margin-bottom: 24px;">
        <span class="badge badge-new" style="margin-bottom: 8px;">Interactive</span>
        <h2 style="font-size: 1.4rem; margin-bottom: 6px; font-weight: 700;">Find Your Perfect E-Bike in 30 Seconds</h2>
        <p style="color: var(--color-text-secondary); font-size: 0.95rem;">Answer 3 quick questions and we'll match you with the ideal ride.</p>
      </div>
      <div class="quiz-widget" id="quiz-widget" style="background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 32px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div class="quiz-progress" style="width: 100%; height: 6px; background: var(--color-border-light); border-radius: 6px; margin-bottom: 24px; overflow: hidden;">
          <div class="quiz-progress-bar" id="quiz-progress-bar" style="height: 100%; width: 0%; background: var(--color-accent); border-radius: 6px; transition: width 0.4s ease;"></div>
        </div>
        <div class="quiz-step active" data-step="1">
          <h3 style="font-size: 1.05rem; margin-bottom: 16px; text-align: center; font-weight: 600;">What's your primary riding style?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" onclick="quizAnswer(1,'commuter',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">🏙️ City Commuting</button>
            <button class="quiz-opt" onclick="quizAnswer(1,'mountain',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">⛰️ Off-Road Trails</button>
            <button class="quiz-opt" onclick="quizAnswer(1,'folding',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">🎒 Compact & Portable</button>
            <button class="quiz-opt" onclick="quizAnswer(1,'cargo',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">📦 Hauling & Utility</button>
          </div>
        </div>
        <div class="quiz-step" data-step="2" style="display: none;">
          <h3 style="font-size: 1.05rem; margin-bottom: 16px; text-align: center; font-weight: 600;">What's your budget range?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" onclick="quizAnswer(2,'budget',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">Under $1,000</button>
            <button class="quiz-opt" onclick="quizAnswer(2,'mid',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">$1,000 – $2,000</button>
            <button class="quiz-opt" onclick="quizAnswer(2,'premium',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">$2,000+</button>
          </div>
        </div>
        <div class="quiz-step" data-step="3" style="display: none;">
          <h3 style="font-size: 1.05rem; margin-bottom: 16px; text-align: center; font-weight: 600;">How far do you need to ride per charge?</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
            <button class="quiz-opt" onclick="quizAnswer(3,'short',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">Under 30 miles</button>
            <button class="quiz-opt" onclick="quizAnswer(3,'medium',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">30–60 miles</button>
            <button class="quiz-opt" onclick="quizAnswer(3,'long',this)" style="padding: 14px 16px; border-radius: var(--radius-sm); border: 2px solid var(--color-border); background: #fff; color: var(--color-text-primary); font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: all 200ms ease; text-align: center;">60+ miles</button>
          </div>
        </div>
        <div class="quiz-step" data-step="4" style="display: none; text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 12px;" id="quiz-result-emoji">🎉</div>
          <h3 style="font-size: 1.3rem; margin-bottom: 8px; font-weight: 700;" id="quiz-result-title">Your Perfect Match!</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: 24px; font-size: 1rem;" id="quiz-result-desc"></p>
          <a class="btn btn-primary" id="quiz-result-link" href={aff2} target="_blank" rel="noopener noreferrer" style="font-size: 1.1rem; padding: 14px 40px;">Shop Your Match →</a>
          <button style="display: block; margin: 20px auto 0; background: none; border: none; color: var(--color-text-muted); font-size: 0.85rem; cursor: pointer; text-decoration: underline;" onclick="quizReset()">↻ Retake Quiz</button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  var quizState = { q1: null, q2: null, q3: null };
  window.quizAnswer = function(step, value, btn) {
    quizState['q' + step] = value;
    var parent = btn.parentElement;
    parent.querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); b.style.borderColor = 'var(--color-border)'; b.style.background = '#fff'; });
    btn.classList.add('selected');
    btn.style.borderColor = 'var(--color-accent)';
    btn.style.background = 'var(--color-accent-light)';
    document.getElementById('quiz-progress-bar').style.width = (step / 3 * 100) + '%';
    setTimeout(function() {
      document.querySelectorAll('.quiz-step[data-step="' + step + '"]')[0].style.display = 'none';
      document.querySelectorAll('.quiz-step[data-step="' + (step + 1) + '"]')[0].style.display = 'block';
      if (step === 3) {
        var q1 = quizState.q1;
        var map = {
          commuter: { emoji: '🏙️', title: 'The Urban Commuter', desc: 'You need a sleek, reliable e-bike for daily commuting. Check out our top commuter picks.' },
          mountain: { emoji: '⛰️', title: 'The Trail Blazer', desc: 'You live for off-road adventure. Our mountain e-bikes are built for any terrain.' },
          folding: { emoji: '🎒', title: 'The City Minimalist', desc: 'Portability is everything. Our folding e-bikes pack down small and ride big.' },
          cargo: { emoji: '📦', title: 'The Family Hauler', desc: 'You need to move people and stuff. Our cargo e-bikes have the power and capacity.' }
        };
        var r = map[q1] || map.commuter;
        document.getElementById('quiz-result-emoji').textContent = r.emoji;
        document.getElementById('quiz-result-title').textContent = r.title;
        document.getElementById('quiz-result-desc').textContent = r.desc;
      }
    }, 300);
  };
  window.quizReset = function() {
    quizState = { q1: null, q2: null, q3: null };
    document.querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); b.style.borderColor = 'var(--color-border)'; b.style.background = '#fff'; });
    document.querySelectorAll('.quiz-step').forEach(function(s) { s.style.display = 'none'; s.classList.remove('active'); });
    document.querySelector('.quiz-step[data-step="1"]').style.display = 'block';
    document.querySelector('.quiz-step[data-step="1"]').classList.add('active');
    document.getElementById('quiz-progress-bar').style.width = '0%';
  };
</script>

<style>
  .quiz-opt:hover {
    border-color: var(--color-accent) !important;
    background: var(--color-accent-light) !important;
  }
  @media (max-width: 1024px) {
    .container > div[style*="grid-template-columns: 1fr 280px"] { grid-template-columns: 1fr !important; }
    aside[style*="position: sticky"] { position: static !important; }
    .bike-review > div[style*="grid-template-columns: 200px 1fr"] { grid-template-columns: 1fr !important; }
    .bike-review > div[style*="grid-template-columns: 200px 1fr"] img { max-height: 240px; }
  }
  @media (max-width: 768px) {
    .bike-review > div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
