let post = posts[slug as string];

// If not in hardcoded posts, check content collection
if (!post) {
  const contentPost = contentPosts.find(p => p.data.slug === slug);
  if (contentPost) {
    const d = contentPost.data;
    const rendered = await contentPost.render();
    post = {
      title: d.title,
      description: d.description,
      image: d.image || 'https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=1200&q=80',
      category: d.category,
      date: d.date,
      author: d.author,
      readTime: '5',
      tags: d.tags,
      isContentPost: true,
      renderedContent: rendered.html,
    };
  }
}

if (!post) {
  return Astro.redirect(`${base}blog`);
}

const formattedDate = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={post.title}
  description={post.description}
  image={post.image}
  type="article"
  publishedTime={new Date(post.date).toISOString()}
  author={post.author}
  tags={post.tags}
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <article class="article-section">
    <div class="container container-narrow">
      <!-- Article Header -->
      <header class="article-header">
        <span class="badge badge-new">{post.category}</span>
        <h1>{post.title}</h1>
        <div class="article-meta">
          <span class="author">{post.author}</span>
          <span class="dot">·</span>
          <time datetime={post.date}>{formattedDate}</time>
          <span class="dot">·</span>
          <span>{post.readTime} min read</span>
        </div>
      </header>

      <!-- Featured Image -->
      <div class="article-featured-image">
        <img src={post.image} alt={post.title} loading="eager" />
      </div>

      <!-- Article Content -->
      {post.isContentPost ? (
        <div class="article-content" set:html={post.renderedContent} />
      ) : (
        <div class="article-content" set:html={post.content} />
      )}

      <!-- Tags -->
      <div class="article-tags">
        {post.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <!-- Share -->
      <div class="share-section">
        <span>Share this article:</span>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="share-btn" aria-label="Share on Twitter">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="share-btn" aria-label="Share on Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <button class="share-btn copy-btn" onclick={`navigator.clipboard.writeText('${Astro.url.toString()}'); this.textContent='✓ Copied!'; setTimeout(() => this.textContent='📋', 2000);`} aria-label="Copy link">
          📋
        </button>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .container-narrow { max-width: 720px; }
  .article-section { padding: 40px 0 80px; }
  .article-header { margin-bottom: 32px; }
  .article-header .badge { margin-bottom: 16px; }
  .article-header h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 16px; line-height: 1.15; }
  .article-meta { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; color: var(--color-text-muted); }
  .author { color: var(--color-accent); font-weight: 500; }
  .article-featured-image { border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 40px; box-shadow: var(--shadow-card); }
  .article-featured-image img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
  .article-content { font-size: 1.05rem; line-height: 1.85; color: var(--color-text-secondary); }
  .article-content :global(.lead) { font-size: 1.2rem; color: var(--color-text-primary); line-height: 1.75; margin-bottom: 32px; font-weight: 500; }
  .article-content :global(h2) { color: var(--color-text-primary); margin: 48px 0 16px; font-size: 1.8rem; }
  .article-content :global(h3) { color: var(--color-text-primary); margin: 32px 0 12px; font-size: 1.35rem; }
  .article-content :global(p) { margin-bottom: 20px; }
  .article-content :global(ul), .article-content :global(ol) { margin: 16px 0 24px; padding-left: 24px; }
  .article-content :global(li) { margin-bottom: 10px; }
  .article-content :global(strong) { color: var(--color-text-primary); }
  .article-content :global(blockquote) { border-left: 3px solid var(--color-accent); padding: 24px 32px; margin: 32px 0; background: var(--color-bg-card); border-radius: 0 var(--radius-md) var(--radius-md) 0; }
  .article-content :global(blockquote p) { font-style: italic; font-size: 1.1rem; color: var(--color-text-primary); margin-bottom: 8px; }
  .article-content :global(blockquote cite) { font-style: normal; font-size: 0.85rem; color: var(--color-text-muted); }
  .article-tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 40px 0; padding-top: 24px; border-top: 1px solid var(--color-border); }
  .tag { padding: 6px 14px; border-radius: 100px; background: var(--color-bg-card); border: 1px solid var(--color-border); font-size: 0.8rem; color: var(--color-text-secondary); }
  .share-section { display: flex; align-items: center; gap: 12px; color: var(--color-text-muted); font-size: 0.85rem; }
  .share-btn { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-text-secondary); cursor: pointer; transition: all var(--transition-fast); font-size: 0; }
  .share-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .copy-btn { font-size: 1rem; background: none; border: none; }

  /* Product Image Gallery */
  .article-content :global(.product-gallery) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
    margin: 32px 0;
  }
  .article-content :global(.gallery-item) {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }
  .article-content :global(.gallery-item:hover) {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }
  .article-content :global(.gallery-item img) {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .article-content :global(.gallery-item:hover img) {
    transform: scale(1.05);
  }
</style>
