---
// Blog Post — dynamic route for all blog posts
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const contentPosts = await getCollection('blog');
  const contentSlugs = new Set(contentPosts.map(p => p.id.replace(/\.mdx?$/, '')));
  const contentPaths = contentPosts.map(p => ({ params: { slug: p.id.replace(/\.mdx?$/, '') } }));
  // Only add product paths for products that DON'T have MDX content yet
  const productPaths = productsData
    .filter(p => !contentSlugs.has(p.slug))
    .map(p => ({ params: { slug: p.slug } }));
  return [...contentPaths, ...productPaths];
}

const { slug } = Astro.params;

// Look up product from our data
const product = productsData.find(p => p.slug === slug);

// Check content collection for MDX posts
const contentPosts = await getCollection('blog');
const cp = contentPosts.find(p => p.id.replace(/\.mdx?$/, '') === slug);
let contentPost = null;
if (cp) {
  const rendered = await cp.render();
  contentPost = { ...cp, rendered };
}

// Build the post object — prefer MDX content when available, supplement with product data
let post: any;
if (contentPost) {
  const d = contentPost.data;
  // Use product data to enrich the post if available
  const prodInfo = product || {};
  post = {
    title: d.title || prodInfo.title,
    description: d.description || prodInfo.excerpt,
    image: d.image || prodInfo.image || 'https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=1200&q=80',
    category: d.category || prodInfo.category || 'Reviews',
    date: d.date || '2026-01-15',
    author: d.author || 'The Electric Bike Superstore',
    readTime: '8',
    tags: d.tags || ['ebike', 'review'],
    content: contentPost.rendered.html,
    isContentPost: true,
    renderedContent: contentPost.rendered.html,
    product: product || null,
  };
} else if (product) {
  const affMatch = product.affiliateUrl.match(/awinmid=(\d+)/);
  post = {
    title: product.title,
    description: product.excerpt,
    image: product.image,
    category: product.category,
    date: '2026-01-15',
    author: 'The Electric Bike Superstore',
    readTime: '8',
    tags: ['ebike', 'review', product.category.toLowerCase(), product.store.toLowerCase()],
    content: product.body,
    isContentPost: false,
    product: {
      ...product,
      affiliateId: affMatch ? affMatch[1] : '123118',
    },
  };
}

if (!post) {
  return Astro.redirect(`${base}blog`);
}

const formattedDate = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={post.title}
  description={post.description}
  image={post.image}
  type="article"
  publishedTime={new Date(post.date).toISOString()}
  author={post.author}
  tags={post.tags}
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <article class="article-section">
    <div class="container container-narrow">

      <!-- Article Header -->
      <header class="article-header">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
          <span class="badge badge-new">{post.category}</span>
          {post.product?.store && <span style="font-size: 0.78rem; color: var(--color-text-muted);">{post.product.store}</span>}
        </div>
        <h1>{post.title}</h1>
        <div class="article-meta">
          <span class="author">{post.author}</span>
          <span class="dot">·</span>
          <time datetime={post.date}>{formattedDate}</time>
          <span class="dot">·</span>
          <span>{post.readTime} min read</span>
        </div>
        {post.product?.rating > 0 && (
          <div style="display: flex; align-items: center; gap: 6px; margin-top: 10px;">
            <div style="display: flex; gap: 2px;">
              {[1,2,3,4,5].map(i => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill={i <= Math.round(post.product.rating) ? "#d69e2e" : "#e1e5e9"} stroke="#d69e2e" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <span style="font-size: 0.88rem; font-weight: 600;">{post.product.rating}/5</span>
            <span style="font-size: 0.82rem; color: var(--color-text-muted);">({post.product.reviews} reviews)</span>
          </div>
        )}
      </header>

      {/* Video embed for products — video rendered separately by Remotion */}
      {post.product?.slug && (
        <div style="margin-bottom: 24px; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
          <video
            controls
            preload="metadata"
            poster={post.image}
            style="width: 100%; display: block; background: #0a0a0f;"
          >
            <source src={`/videos/${post.product.slug}-promo.mp4`} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
          <div style="background: #2d8a4e; color: #fff; padding: 8px 16px; font-size: 0.82rem; font-weight: 600; text-align: center;">
            🎬 Product Promo Video — {post.product.shortTitle}
          </div>
        </div>
      )}

      {/* Featured Image */}
      <div class="article-featured-image">
        <img src={post.image} alt={post.title} loading="eager" />
      </div>

      <!-- Price CTA (for products) -->
      {post.product?.price && (
        <div style="background: var(--color-accent-light); border: 1px solid rgba(45,138,78,0.2); border-radius: var(--radius-md); padding: 20px; margin-bottom: 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
          <div>
            <div style="font-size: 0.78rem; color: var(--color-text-muted); margin-bottom: 2px;">Current Price at {post.product.store}</div>
            <div style="display: flex; align-items: baseline; gap: 8px;">
              {post.product.oldPrice && <span style="font-size: 0.9rem; color: var(--color-text-muted); text-decoration: line-through;">{post.product.oldPrice}</span>}
              <span style="font-size: 1.6rem; font-weight: 800; color: var(--color-accent);">{post.product.price}</span>
            </div>
          </div>
          <!-- START ADVERTISER: {post.product.store} from awin.com -->
          <a rel="sponsored" href={`https://www.awin1.com/cread.php?s=3682925&v=${post.product.affiliateId}&q=494573&r=2915733`} target="_blank" rel="noopener noreferrer">
            <img src={`https://www.awin1.com/cshow.php?s=3682925&v=${post.product.affiliateId}&q=494573&r=2915733`} border="0" alt={`Buy ${post.product.shortTitle} at ${post.product.store}`} style="max-width:100%;height:auto;" />
          </a>
          <!-- END ADVERTISER: {post.product.store} from awin.com -->
        </div>
      )}

      <!-- Article Content -->
      {post.isContentPost ? (
        <div class="article-content" set:html={post.renderedContent} />
      ) : (
        <div class="article-content" set:html={post.content} />
      )}

      <!-- Specs Table (for products) -->
      {post.product?.specs && Object.keys(post.product.specs).length > 0 && (
        <div style="margin: 32px 0; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
          <div style="background: var(--color-accent); color: #fff; padding: 12px 20px; font-weight: 700; font-size: 0.95rem;">
            Full Specifications
          </div>
          <div style="padding: 16px 20px;">
            {Object.entries(post.product.specs).map(([key, value]) => (
              <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--color-border-light); font-size: 0.9rem;">
                <span style="color: var(--color-text-muted); font-weight: 500;">{key}</span>
                <span style="font-weight: 700; color: var(--color-text-primary);">{value}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Pros & Cons (for products) -->
      {post.product?.pros?.length > 0 && (
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 32px 0;">
          <div style="background: #e8f5e9; border-radius: var(--radius-md); padding: 20px;">
            <h3 style="font-size: 1rem; color: #2d8a4e; font-weight: 700; margin-bottom: 10px;">👍 What We Like</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {post.product.pros.map((pro: string) => (
                <li style="font-size: 0.88rem; color: #2d5a3a; padding: 5px 0; border-bottom: 1px solid rgba(45,138,78,0.1);">✓ {pro}</li>
              ))}
            </ul>
          </div>
          <div style="background: #fef2f2; border-radius: var(--radius-md); padding: 20px;">
            <h3 style="font-size: 1rem; color: #c53030; font-weight: 700; margin-bottom: 10px;">👎 What Could Be Better</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {post.product.cons.map((con: string) => (
                <li style="font-size: 0.88rem; color: #742a2a; padding: 5px 0; border-bottom: 1px solid rgba(197,48,48,0.1);">✗ {con}</li>
              ))}
            </ul>
          </div>
        </div>
      )}

      <!-- Product Gallery (for products) -->
      {post.product?.gallery?.length > 1 && (
        <div style="margin: 32px 0;">
          <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 12px;">Product Gallery</h3>
          <div class="product-gallery">
            {post.product.gallery.map((img: string) => (
              <div class="gallery-item">
                <img src={img} alt={post.title} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Bottom CTA -->
      {post.product?.affiliateId && (
        <div style="text-align: center; margin: 40px 0; padding: 32px; background: var(--color-bg-elevated); border: 2px solid var(--color-accent); border-radius: var(--radius-lg);">
          <h3 style="font-size: 1.2rem; margin-bottom: 8px;">Ready to Buy the {post.product.shortTitle}?</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: 16px;">Get the best price at {post.product.store} with free shipping and 2-year warranty.</p>
          <!-- START ADVERTISER: {post.product.store} from awin.com -->
          <a rel="sponsored" href={`https://www.awin1.com/cread.php?s=3682925&v=${post.product.affiliateId}&q=494573&r=2915733`} target="_blank" rel="noopener noreferrer">
            <img src={`https://www.awin1.com/cshow.php?s=3682925&v=${post.product.affiliateId}&q=494573&r=2915733`} border="0" alt={`Check Price at ${post.product.store}`} style="max-width:100%;height:auto;" />
          </a>
          <!-- END ADVERTISER: {post.product.store} from awin.com -->
        </div>
      )}

      <!-- Shop By Store — 4 Affiliate Partners -->
      <div style="margin: 48px 0 32px; padding: 28px; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
        <h3 style="font-size: 1.15rem; margin-bottom: 6px; text-align: center;">🏪 Shop By Store</h3>
        <p style="color: var(--color-text-muted); font-size: 0.88rem; text-align: center; margin-bottom: 20px;">Browse electric bikes from our four trusted affiliate partners. Free shipping, 2-year warranty, and competitive pricing on every model.</p>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 16px;">
          <a rel="sponsored" href="https://www.awin1.com/cread.php?awinmid=123118&awinaffid=2915733" target="_blank" rel="noopener noreferrer" style="display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px 16px; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-md); text-decoration: none; transition: all var(--transition-fast);">
            <span style="font-size: 1.8rem;">�</span>
            <span style="font-weight: 700; color: var(--color-text-primary); font-size: 0.95rem;">Burchda Bikes</span>
            <span style="font-size: 0.78rem; color: var(--color-text-muted); text-align: center;">High-performance MTB & commuter e-bikes</span>
            <span style="font-size: 0.82rem; color: var(--color-accent); font-weight: 600;">Shop Burchda →</span>
          </a>
          <a rel="sponsored" href="https://www.awin1.com/cread.php?awinmid=124136&awinaffid=2915733" target="_blank" rel="noopener noreferrer" style="display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px 16px; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-md); text-decoration: none; transition: all var(--transition-fast);">
            <span style="font-size: 1.8rem;">🏪</span>
            <span style="font-weight: 700; color: var(--color-text-primary); font-size: 0.95rem;">King Bull Bike</span>
            <span style="font-size: 0.78rem; color: var(--color-text-muted); text-align: center;">Top-rated direct-to-consumer brand</span>
            <span style="font-size: 0.82rem; color: var(--color-accent); font-weight: 600;">Shop King Bull →</span>
          </a>
          <a rel="sponsored" href="https://www.awin1.com/cread.php?awinmid=98557&awinaffid=2915733" target="_blank" rel="noopener noreferrer" style="display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px 16px; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-md); text-decoration: none; transition: all var(--transition-fast);">
            <span style="font-size: 1.8rem;">�</span>
            <span style="font-weight: 700; color: var(--color-text-primary); font-size: 0.95rem;">Vivi Bikes</span>
            <span style="font-size: 0.78rem; color: var(--color-text-muted); text-align: center;">Premium features at accessible prices</span>
            <span style="font-size: 0.82rem; color: var(--color-accent); font-weight: 600;">Shop Vivi →</span>
          </a>
          <a rel="sponsored" href="https://www.amazon.com/stores/page/F97C0FA7-87EC-4A90-A10E-AA86092556D7?ingress=0&lp_context_query=highest+quality+ebike&visitId=ed4531b0-d9f6-48b6-bf43-e0dc852649ac&lp_query=highest+quality+ebike&lp_slot=desktop-hsa-3psl&store_ref=SB_A05718453SMTU8GBJIH8R-A09242562WEDIXMHOCGAQ&linkCode=ll2&tag=techbot00-20&linkId=79c593009ee56b007df3ae2d0d32036e&language=en_US&ref_=as_li_ss_tl" target="_blank" rel="noopener noreferrer" style="display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px 16px; background: #fff8e1; border: 1px solid #FF9900; border-radius: var(--radius-md); text-decoration: none; transition: all var(--transition-fast);">
            <span style="font-size: 1.8rem;">�</span>
            <span style="font-weight: 700; color: var(--color-text-primary); font-size: 0.95rem;">Amazon</span>
            <span style="font-size: 0.78rem; color: var(--color-text-muted); text-align: center;">Highest quality e-bikes, fast shipping</span>
            <span style="font-size: 0.82rem; color: #FF9900; font-weight: 600;">Shop Amazon →</span>
          </a>
        </div>
        <p style="font-size: 0.72rem; color: var(--color-text-muted); text-align: center; margin: 0; font-style: italic;">Disclosure: As an affiliate partner, we may earn a commission from qualifying purchases. This does not influence our reviews or recommendations.</p>
      </div>

      <!-- Tags -->
      <div class="article-tags">
        {post.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <!-- Share -->
      <div class="share-section">
        <span>Share this article:</span>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="share-btn" aria-label="Share on Twitter">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="share-btn" aria-label="Share on Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>

      <!-- Affiliate Disclaimer -->
      <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--color-border);">
        <em>Disclosure: As an affiliate partner, we may earn a commission from qualifying purchases made through links on this page. This does not influence our reviews or recommendations. All opinions are our own based on thorough research and testing.</em>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .container-narrow { max-width: 720px; }
  .article-section { padding: 32px 0 60px; }
  .article-header { margin-bottom: 24px; }
  .article-header h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 12px; line-height: 1.15; }
  .article-meta { display: flex; align-items: center; gap: 6px; font-size: 0.88rem; color: var(--color-text-muted); }
  .author { color: var(--color-accent); font-weight: 500; }
  .article-featured-image { border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 32px; box-shadow: var(--shadow-card); }
  .article-featured-image img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
  .article-content { font-size: 1.05rem; line-height: 1.85; color: var(--color-text-secondary); }
  .article-content :global(.lead) { font-size: 1.15rem; color: var(--color-text-primary); line-height: 1.75; margin-bottom: 28px; font-weight: 500; }
  .article-content :global(h2) { color: var(--color-text-primary); margin: 40px 0 14px; font-size: 1.6rem; }
  .article-content :global(h3) { color: var(--color-text-primary); margin: 28px 0 10px; font-size: 1.25rem; }
  .article-content :global(p) { margin-bottom: 18px; }
  .article-content :global(ul), .article-content :global(ol) { margin: 14px 0 20px; padding-left: 24px; }
  .article-content :global(li) { margin-bottom: 8px; }
  .article-content :global(strong) { color: var(--color-text-primary); }
  .article-content :global(blockquote) { border-left: 3px solid var(--color-accent); padding: 20px 28px; margin: 28px 0; background: var(--color-bg-elevated); border-radius: 0 var(--radius-md) var(--radius-md) 0; }
  .article-tags { display: flex; flex-wrap: wrap; gap: 6px; margin: 32px 0; padding-top: 20px; border-top: 1px solid var(--color-border); }
  .tag { padding: 5px 12px; border-radius: 100px; background: var(--color-bg-elevated); border: 1px solid var(--color-border); font-size: 0.78rem; color: var(--color-text-secondary); }
  .share-section { display: flex; align-items: center; gap: 10px; color: var(--color-text-muted); font-size: 0.82rem; }
  .share-btn { display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: var(--radius-sm); background: var(--color-bg-elevated); border: 1px solid var(--color-border); color: var(--color-text-secondary); cursor: pointer; transition: all var(--transition-fast); }
  .share-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .product-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px; }
  .product-gallery .gallery-item { border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--color-border); transition: transform 0.2s ease; cursor: pointer; }
  .product-gallery .gallery-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-card-hover); }
  .product-gallery .gallery-item img { width: 100%; height: 140px; object-fit: cover; display: block; }
  @media (max-width: 768px) {
    .article-content :global(h2) { font-size: 1.4rem; }
    div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
