        <a href="https://hnrqqt-an.myshopify.com/products/premium-helmet" class="btn btn-primary" style="font-size: 1.15rem; padding: 16px 48px; display: inline-block; text-decoration: none; border-radius: 8px;">Buy Now — $149</a>
        <p style="margin-top: 12px; color: var(--color-text-muted); font-size: 0.9rem;">Free shipping · 30-day returns · 2-year warranty</p>
      </div>
    `,
  },

  'shop-e-bike-security-bundle': {
