---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

// Load content collection posts
const contentPosts = await getCollection('blog');
const contentPostItems = contentPosts.map(p => ({
  slug: p.id.replace(/\.mdx?$/, ''),
  title: p.data.title,
  excerpt: p.data.description,
  image: p.data.image || 'https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=800&q=80',
  category: p.data.category,
  date: p.data.date,
  readTime: '5',
  author: p.data.author,
  isContentPost: true,
}));

// Merge products + content posts, sort by date
const allPosts = [...productsData, ...contentPostItems]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const categories = ['All', ...new Set(allPosts.map(p => p.category))];
---

<BaseLayout
  title="Electric Bike Reviews & Buying Guides — The Electric Bike Superstore"
  description="Read our in-depth reviews of the best electric bikes from Burchda, King Bull, and Vivi. Real specs, real prices, real testing."
  type="website"
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <section class="section-sm" style="padding-top: 32px;">
    <div class="container">
      <div class="page-header">
        <h1>Electric Bike <span class="gradient-text">Reviews & Guides</span></h1>
        <p>Honest reviews, expert buying advice, and maintenance tips — tested by real riders.</p>
      </div>

      <!-- Category Filter -->
      <div class="filter-bar">
        {categories.map(cat => (
          <button class="filter-btn" data-category={cat}>{cat}</button>
        ))}
      </div>

      <!-- Search -->
      <div class="search-bar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="blog-search" placeholder="Search reviews & guides..." aria-label="Search articles" />
      </div>

      <!-- Posts List (EBR-style) -->
      <div id="posts-grid" style="margin-top: 28px;">
        {allPosts.map(post => (
          <div class="post-item" data-category={post.category} data-title={post.title.toLowerCase()}>
            <article class="blog-card" style="margin-bottom: 24px;">
              <a href={`${base}blog/${post.slug}/`} style="display: block;">
                <div style="display: grid; grid-template-columns: 240px 1fr; gap: 20px; align-items: start;">
                  <div style="border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--color-border);">
                    <img src={post.image} alt={post.title} loading="lazy" style="width: 100%; aspect-ratio: 4/3; object-fit: cover;" />
                  </div>
                  <div>
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                      <span class="badge badge-new">{post.category}</span>
                      {post.store && <span style="font-size: 0.75rem; color: var(--color-text-muted);">{post.store}</span>}
                    </div>
                    <h3 style="font-size: 1.1rem; margin-bottom: 6px; font-weight: 700; line-height: 1.3;">
                      {post.title}
                    </h3>
                    {post.rating > 0 && (
                      <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 6px;">
                        <div style="display: flex; gap: 1px;">
                          {[1,2,3,4,5].map(i => (
                            <svg width="12" height="12" viewBox="0 0 24 24" fill={i <= Math.round(post.rating) ? "#d69e2e" : "#e1e5e9"} stroke="#d69e2e" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                          ))}
                        </div>
                        <span style="font-size: 0.78rem; color: var(--color-text-muted);">{post.rating}/5</span>
                      </div>
                    )}
                    {post.price && (
                      <div style="margin-bottom: 8px;">
                        {post.oldPrice && <span style="font-size: 0.82rem; color: var(--color-text-muted); text-decoration: line-through; margin-right: 6px;">{post.oldPrice}</span>}
                        <span style="font-size: 1.15rem; font-weight: 800; color: var(--color-accent);">{post.price}</span>
                      </div>
                    )}
                    <p style="color: var(--color-text-secondary); font-size: 0.88rem; line-height: 1.6;">{post.excerpt}</p>
                    <span style="display: inline-flex; align-items: center; gap: 4px; margin-top: 8px; font-size: 0.85rem; font-weight: 600; color: var(--color-accent);">
                      Read Review
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            </article>
          </div>
        ))}
      </div>

      <div id="no-results" style="display:none; text-align:center; padding: 64px 0;">
        <p style="color: var(--color-text-muted); font-size: 1.1rem;">No reviews found. Try a different search or filter.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { text-align: center; margin-bottom: 32px; padding: 32px 0 16px; border-bottom: 1px solid var(--color-border); }
  .page-header h1 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 8px; }
  .page-header p { color: var(--color-text-secondary); font-size: 1rem; }
  .filter-bar { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-bottom: 20px; }
  .filter-btn { padding: 6px 16px; border-radius: 100px; font-size: 0.82rem; font-weight: 500; font-family: var(--font-sans); cursor: pointer; background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-text-secondary); transition: all var(--transition-fast); }
  .filter-btn:hover, .filter-btn.active { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }
  .search-bar { display: flex; align-items: center; gap: 10px; max-width: 400px; margin: 0 auto; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 10px 16px; transition: border-color var(--transition-fast); }
  .search-bar:focus-within { border-color: var(--color-accent); box-shadow: 0 0 0 3px rgba(45,138,78,0.12); }
  .search-bar svg { color: var(--color-text-muted); flex-shrink: 0; }
  .search-bar input { flex: 1; background: none; border: none; color: var(--color-text-primary); font-size: 0.88rem; font-family: var(--font-sans); }
  .search-bar input:focus { outline: none; }
  .search-bar input::placeholder { color: var(--color-text-muted); }
  @media (max-width: 768px) {
    .blog-card > a > div[style*="grid-template-columns"] { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const posts = document.querySelectorAll('.post-item');
  const search = document.getElementById('blog-search');
  const noResults = document.getElementById('no-results');
  const grid = document.getElementById('posts-grid');
  let activeCategory = 'all';
  filterBtns.forEach(btn => { if (btn.dataset.category === 'All') btn.classList.add('active'); });
  function filterPosts() {
    const query = search?.value.toLowerCase() || '';
    let visible = 0;
    posts.forEach(post => {
      const cat = post.dataset.category || '';
      const title = post.dataset.title || '';
      const matchCat = activeCategory === 'all' || activeCategory === 'All' || cat === activeCategory;
      const matchSearch = !query || title.includes(query);
      const show = matchCat && matchSearch;
      post.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    if (grid) grid.style.display = visible === 0 ? 'none' : '';
  }
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.category || 'all';
      filterPosts();
    });
  });
  search?.addEventListener('input', filterPosts);
</script>
