---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — The Electric Bike Superstore"
  description="Questions about e-bikes or our recommendations? Contact The Electric Bike Superstore team. We're here to help you find the perfect ride."
  type="website"
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <section style="padding: 40px 0;">
    <div class="container" style="max-width: 700px;">
      <!-- Breadcrumb -->
      <nav style="margin-bottom: 24px; font-size: 0.85rem; color: var(--color-text-muted);">
        <a href="/" style="color: var(--color-text-muted);">Home</a>
        <span style="margin: 0 6px;">›</span>
        <span>Contact</span>
      </nav>

      <h1 style="font-size: 2rem; margin-bottom: 8px; font-weight: 800;">Contact Us</h1>
      <p style="color: var(--color-text-secondary); margin-bottom: 32px; font-size: 1.05rem;">
        Have a question about an e-bike? Need help choosing? We typically respond within 24 hours.
      </p>

      <form class="card" style="padding: 32px; margin-bottom: 32px;" onsubmit="event.preventDefault(); alert('Thanks for reaching out! We\'ll get back to you within 24 hours.');">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
          <div>
            <label for="name" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Name</label>
            <input type="text" id="name" required placeholder="Your name" aria-label="Your name" style="width: 100%; padding: 10px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); font-size: 0.95rem; font-family: var(--font-sans);" />
          </div>
          <div>
            <label for="email" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Email</label>
            <input type="email" id="email" required placeholder="you@example.com" aria-label="Your email" style="width: 100%; padding: 10px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); font-size: 0.95rem; font-family: var(--font-sans);" />
          </div>
        </div>
        <div style="margin-bottom: 16px;">
          <label for="subject" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Subject</label>
          <select id="subject" aria-label="Subject" style="width: 100%; padding: 10px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); font-size: 0.95rem; font-family: var(--font-sans); background: #fff; cursor: pointer;">
            <option>General Inquiry</option>
            <option>Product Question</option>
            <option>Order Support</option>
            <option>Partnership</option>
          </select>
        </div>
        <div style="margin-bottom: 20px;">
          <label for="message" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Message</label>
          <textarea id="message" rows="5" required placeholder="Tell us what's on your mind..." aria-label="Your message" style="width: 100%; padding: 10px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--color-border); font-size: 0.95rem; font-family: var(--font-sans); resize: vertical; min-height: 120px;"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Send Message</button>
      </form>

      <div class="card" style="padding: 24px;">
        <h3 style="font-size: 1rem; margin-bottom: 12px; font-weight: 600;">Other Ways to Reach Us</h3>
        <ul style="list-style: none; padding: 0;">
          <li style="padding: 8px 0; border-bottom: 1px solid var(--color-border-light);">
            <strong>Email:</strong> <a href="mailto:hello@theelectricbikesuperstore.com">hello@theelectricbikesuperstore.com</a>
          </li>
          <li style="padding: 8px 0; border-bottom: 1px solid var(--color-border-light);">
            <strong>Location:</strong> Portland, Oregon, USA
          </li>
          <li style="padding: 8px 0;">
            <strong>Response time:</strong> Within 24 hours
          </li>
        </ul>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "The Electric Bike Superstore",
    "url": "https://theelectricbikesuperstore.com",
    "email": "hello@theelectricbikesuperstore.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Portland",
      "addressRegion": "Oregon",
      "addressCountry": "US"
    },
    "sameAs": [
      "https://twitter.com/ebikesuperstore",
      "https://www.instagram.com/theelectricbikesuperstore/"
    ]
  }
  </script>
</BaseLayout>
