---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProductCard from '@components/ProductCard.astro';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

// Only show products with a price (exclude standalone buying guides)
const products = productsData.filter(p => p.price);

// Build category list from actual product data
const categorySet = new Set(products.map(p => p.category));
const categories = ['All', ...Array.from(categorySet).sort()];

// Build store list
const storeSet = new Set(products.map(p => p.store).filter(Boolean));
const stores = ['All', ...Array.from(storeSet).sort()];

// Parse price strings ("$1,199") into numbers for the ProductCard component
function parsePrice(p: string | undefined): number {
  if (!p) return 0;
  return parseFloat(p.replace(/[$,]/g, ''));
}

function parseOldPrice(p: string | undefined): number | undefined {
  if (!p) return undefined;
  const n = parseFloat(p.replace(/[$,]/g, ''));
  return n > 0 ? n : undefined;
}
---

<BaseLayout
  title="Electric Bikes For Sale — Compare Top Models & Prices | The Electric Bike Superstore"
  description="Compare electric bikes from Burchda, King Bull, and Vivi. Real specs, current prices, and direct links to buy."
  type="website"
  canonicalURL={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <section class="section-sm" style="padding-top: 32px;">
    <div class="container">
      <div class="page-header">
        <h1>Electric Bikes <span class="gradient-text">For Sale</span></h1>
        <p>Browse top-rated electric bikes from trusted brands. Compare specs, prices, and buy direct from authorized sellers.</p>
      </div>

      <!-- Store Filter -->
      <div class="filter-bar" style="margin-bottom: 12px;">
        {stores.map(store => (
          <button class="filter-btn" data-store={store}>{store}</button>
        ))}
      </div>

      <!-- Category Filter -->
      <div class="filter-bar">
        {categories.map(cat => (
          <button class="filter-btn" data-category={cat}>{cat}</button>
        ))}
      </div>

      <!-- Search -->
      <div class="search-bar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="products-search" placeholder="Search by name, brand, or category..." aria-label="Search electric bikes" />
      </div>

      <!-- Results Count -->
      <div id="results-count" style="text-align: center; color: var(--color-text-muted); font-size: 0.85rem; margin: 16px 0;">
        Showing {products.length} products
      </div>

      <!-- Products Grid -->
      <div id="products-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; margin-top: 24px;">
        {products.map(product => (
          <div
            class="product-item"
            data-category={product.category}
            data-store={product.store}
            data-title={product.title.toLowerCase()}
            data-slug={product.slug}
          >
            <ProductCard
              title={product.title}
              slug={product.slug}
              price={parsePrice(product.price)}
              originalPrice={parseOldPrice(product.oldPrice)}
              image={product.image}
              category={product.category}
              rating={product.rating}
              reviews={product.reviews}
              affiliateUrl={product.affiliateUrl}
              productUrl={product.productUrl}
            />
          </div>
        ))}
      </div>

      <div id="no-results" style="display:none; text-align:center; padding: 64px 0;">
        <p style="color: var(--color-text-muted); font-size: 1.1rem;">No bikes match your filters. Try a different search or category.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 32px;
    padding: 32px 0 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: 8px;
  }
  .page-header p {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }
  .filter-bar {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 12px;
  }
  .filter-btn {
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    font-family: var(--font-sans);
    cursor: pointer;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .search-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 480px;
    margin: 0 auto;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 10px 16px;
    transition: border-color var(--transition-fast);
  }
  .search-bar:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(45,138,78,0.12);
  }
  .search-bar svg {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  .search-bar input {
    flex: 1;
    background: none;
    border: none;
    color: var(--color-text-primary);
    font-size: 0.88rem;
    font-family: var(--font-sans);
  }
  .search-bar input:focus { outline: none; }
  .search-bar input::placeholder { color: var(--color-text-muted); }
</style>

<script>
  // State for the two filter dimensions + search
  let activeCategory = 'All';
  let activeStore = 'All';
  let searchQuery = '';

  const categoryBtns = document.querySelectorAll('[data-category]');
  const storeBtns =  document.querySelectorAll('[data-store]');
  const searchInput = document.getElementById('products-search');
  const grid = document.getElementById('products-grid');
  const noResults = document.getElementById('no-results');
  const resultsCount = document.getElementById('results-count');
  const items = () => document.querySelectorAll('.product-item');

  // Initialize active state
  categoryBtns.forEach(b => { if (b.dataset.category === 'All') b.classList.add('active'); });
  storeBtns.forEach(b => { if (b.dataset.store === 'All') b.classList.add('active'); });

  function filterProducts() {
    let visible = 0;
    items().forEach(el => {
      const cat = el.dataset.category || '';
      const store = el.dataset.store || '';
      const title = (el.dataset.title || '') + ' ' + (el.dataset.slug || '').replace(/-/g, ' ');
      const matchCat = activeCategory === 'All' || cat === activeCategory;
      const matchStore = activeStore === 'All' || store === activeStore;
      const matchSearch = !searchQuery || title.includes(searchQuery);
      const show = matchCat && matchStore && matchSearch;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    if (grid) grid.style.display = visible === 0 ? 'none' : '';
    if (resultsCount) resultsCount.textContent = `Showing ${visible} ${visible === 1 ? 'product' : 'products'}`;
  }

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      categoryBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.category || 'All';
      filterProducts();
    });
  });

  storeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      storeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeStore = btn.dataset.store || 'All';
      filterProducts();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    filterProducts();
  });

  // Run once on load in case URL has hash or browser restores values
  filterProducts();
</script>
