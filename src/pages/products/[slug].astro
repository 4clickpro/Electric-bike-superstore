---
// Product Detail — dynamic route for product pages
import BaseLayout from '@layouts/BaseLayout.astro';
import productsData from '@data/products.json';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  return productsData.map((p: any) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const product = productsData.find((p: any) => p.slug === slug);

if (!product) {
  return Astro.redirect(`${base}products`);
}

const hasDiscount = product.originalPrice && product.originalPrice > product.price;
const discountPercent = hasDiscount ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100) : 0;
const siteUrl = Astro.site?.toString() || 'https://celestial-goods.com';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Breadcrumb structured data
const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: `${siteUrl}/products` },
    { '@type': 'ListItem', position: 3, name: product.category, item: `${siteUrl}/products?category=${product.category}` },
    { '@type': 'ListItem', position: 4, name: product.title },
  ],
};

// Related products (same category, exclude current)
const relatedProducts = productsData
  .filter((p: any) => p.category === product.category && p.slug !== product.slug)
  .slice(0, 3);
---

<BaseLayout
  title={product.title}
  description={product.description}
  image={product.image}
  type="product"
  price={product.price.toFixed(2)}
  currency="USD"
  availability="https://schema.org/InStock"
  rating={product.rating}
  reviews={product.reviews}
  canonicalURL={pageUrl}
>
  <section class="section-sm">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={base}>Home</a>
        <span>/</span>
        <a href={`${base}products`}>Shop</a>
        <span>/</span>
        <a href={`${base}products?category=${product.category}`}>{product.category}</a>
        <span>/</span>
        <span aria-current="page">{product.title}</span>
      </nav>

      <!-- Breadcrumb Structured Data -->
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD, null, 2)} />

      <div class="product-detail">
        <!-- Image -->
        <div class="product-gallery">
          <div class="main-image">
            <img src={product.image} alt={product.title} loading="eager" />
            {product.badge && (
              <span class={`badge badge-${product.badge === 'sale' ? 'sale' : 'new'}`}>
                {product.badge === 'sale' ? `${discountPercent}% OFF` : product.badge}
              </span>
            )}
          </div>
        </div>

        <!-- Info -->
        <div class="product-info">
          <span class="category-tag">{product.category}</span>
          <h1>{product.title}</h1>

          <div class="product-rating">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg width="18" height="18" viewBox="0 0 24 24" fill={i < Math.round(product.rating) ? '#fbbf24' : 'none'} stroke={i < Math.round(product.rating) ? '#fbbf24' : '#6b5e8a'} stroke-width="1.5" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
            <span class="rating-text">{product.rating} ({product.reviews} reviews)</span>
          </div>

          <div class="price-block">
            <span class="current-price">${product.price.toFixed(2)}</span>
            {hasDiscount && <span class="original-price">${product.originalPrice.toFixed(2)}</span>}
            {hasDiscount && <span class="badge badge-sale">Save ${(product.originalPrice - product.price).toFixed(2)}</span>}
          </div>

          <p class="product-description">{product.description}</p>

          <div class="product-actions">
            <div class="quantity-selector">
              <button class="qty-btn" id="qty-minus" aria-label="Decrease quantity">−</button>
              <span id="qty-display">1</span>
              <button class="qty-btn" id="qty-plus" aria-label="Increase quantity">+</button>
            </div>
            <button class="btn btn-primary add-to-cart-main" id="add-to-cart-main" data-product={JSON.stringify({ slug: product.slug, title: product.title, price: product.price, image: product.image })}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              Add to Cart
            </button>
          </div>

          <!-- Details accordion -->
          <details class="details-accordion" open>
            <summary>Product Details</summary>
            <ul>
              {product.details.map((detail: string) => (
                <li>{detail}</li>
              ))}
            </ul>
          </details>

          <details class="details-accordion">
            <summary>Shipping & Returns</summary>
            <p>Free shipping on orders over $75. Standard delivery: 5-7 business days. Express delivery: 2-3 business days. 30-day hassle-free returns on all products.</p>
          </details>
        </div>
      </div>

      <!-- Related Products -->
      {relatedProducts.length > 0 && (
        <div style="margin-top: 80px;">
          <h2 style="margin-bottom: 32px;">You May Also <span class="gradient-text">Like</span></h2>
          <div class="grid-3">
            {relatedProducts.map((p: any) => (
              <a href={`${base}products/${p.slug}`} style="text-decoration: none;">
                <div class="card related-card">
                  <div class="related-image">
                    <img src={p.image} alt={p.title} loading="lazy" />
                  </div>
                  <div class="related-body">
                    <h4>{p.title}</h4>
                    <span class="price">${p.price.toFixed(2)}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 40px;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--color-text-primary);
  }

  .product-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .main-image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-card);
    box-shadow: var(--shadow-card);
  }

  .main-image img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .main-image .badge {
    position: absolute;
    top: 16px;
    right: 16px;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .category-tag {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .product-info h1 {
    font-size: 2.2rem;
    line-height: 1.2;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .rating-text {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-left: 8px;
  }

  .price-block {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .current-price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .original-price {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .product-description {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.8;
  }

  .product-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .qty-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-card);
    border: none;
    color: var(--color-text-primary);
    font-size: 1.2rem;
    cursor: pointer;
    transition: background var(--transition-fast);
    font-family: var(--font-sans);
  }

  .qty-btn:hover {
    background: var(--color-bg-hover);
  }

  #qty-display {
    width: 48px;
    text-align: center;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .add-to-cart-main {
    flex: 1;
    min-width: 200px;
    justify-content: center;
  }

  .details-accordion {
    border-top: 1px solid var(--color-border);
    padding: 20px 0;
  }

  .details-accordion summary {
    font-weight: 600;
    cursor: pointer;
    color: var(--color-text-primary);
    font-size: 0.95rem;
    list-style: none;
  }

  .details-accordion summary::-webkit-details-marker {
    display: none;
  }

  .details-accordion summary::after {
    content: '+';
    float: right;
    font-size: 1.2rem;
    color: var(--color-text-muted);
  }

  .details-accordion[open] summary::after {
    content: '−';
  }

  .details-accordion ul {
    margin: 16px 0 8px;
    padding-left: 20px;
  }

  .details-accordion li {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin-bottom: 8px;
  }

  .details-accordion p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin-top: 16px;
  }

  .related-card {
    padding: 0;
  }

  .related-image {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--transition-smooth);
  }

  .related-card:hover .related-image img {
    transform: scale(1.05);
  }

  .related-body {
    padding: 16px;
  }

  .related-body h4 {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .related-body .price {
    font-size: 0.95rem;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .product-detail {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .product-info h1 {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  // Quantity selector
  let qty = 1;
  const display = document.getElementById('qty-display');
  document.getElementById('qty-minus')?.addEventListener('click', () => { if (qty > 1) { qty--; if (display) display.textContent = String(qty); } });
  document.getElementById('qty-plus')?.addEventListener('click', () => { qty++; if (display) display.textContent = String(qty); });

  // Add to cart
  document.getElementById('add-to-cart-main')?.addEventListener('click', function(this: HTMLElement) {
    const product = JSON.parse(this.dataset.product || '{}');
    const cart = JSON.parse(localStorage.getItem('celestial-cart') || '[]');
    const existing = cart.find((item: any) => item.slug === product.slug);
    if (existing) {
      existing.quantity += qty;
    } else {
      cart.push({ ...product, quantity: qty });
    }
    localStorage.setItem('celestial-cart', JSON.stringify(cart));
    // Dispatch custom event for same-tab cart updates
    window.dispatchEvent(new CustomEvent('cart-updated'));

    this.textContent = '✓ Added!';
    setTimeout(() => {
      this.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg> Add to Cart`;
    }, 1500);
  });
</script>
