---
// SEO component — inject comprehensive meta tags for max Google ranking
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  canonicalURL?: string;
  noindex?: boolean;
  price?: string;
  currency?: string;
  availability?: string;
  rating?: number;
  reviews?: number;
}

const {
  title = 'The Electric Bike Superstore — Premium E-Bikes & Expert Guides',
  description = 'Discover top-rated electric bikes, expert buying guides, and e-bike gear. Ride farther, ride smarter with The Electric Bike Superstore.',
  image = '/og-default.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'Celestial Goods',
  tags = [],
  canonicalURL,
  noindex = false,
  price,
  currency = 'USD',
  availability,
  rating,
  reviews,
} = Astro.props;

const siteName = 'The Electric Bike Superstore';
const twitterHandle = '@ebikesuperstore';
const fullTitle = type === 'article' || type === 'product'
  ? `${title} — ${siteName}`
  : title;
const siteUrl = Astro.site?.toString() || 'https://theelectricbikesuperstore.com';
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const canonical = canonicalURL || Astro.url.toString();

// Build JSON-LD structured data
let structuredData = {};
if (type === 'article') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description: description,
    image: fullImage,
    author: { '@type': 'Person', name: author },
    publisher: {
      '@type': 'Organization',
      name: siteName,
      url: siteUrl,
      logo: { '@type': 'ImageObject', url: `${siteUrl}/og-default.png` }
    },
    datePublished: publishedTime || new Date().toISOString(),
    dateModified: modifiedTime || publishedTime || new Date().toISOString(),
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    keywords: tags.join(', '),
  };
} else if (type === 'product') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: title,
    description: description,
    image: fullImage,
    brand: { '@type': 'Brand', name: siteName },
    ...(rating && reviews ? {
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: rating,
        reviewCount: reviews,
        bestRating: '5',
      },
    } : {}),
    offers: {
      '@type': 'Offer',
      price: price,
      priceCurrency: currency,
      availability: availability || 'https://schema.org/InStock',
      url: canonical,
      seller: {
        '@type': 'Organization',
        name: siteName,
        url: siteUrl,
      },
    },
  };
} else {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: siteUrl,
    description: description,
    publisher: {
      '@type': 'Organization',
      name: siteName,
      url: siteUrl,
      logo: { '@type': 'ImageObject', url: `${siteUrl}/og-default.png` },
      sameAs: [
        'https://twitter.com/ebikesuperstore',
        'https://www.instagram.com/theelectricbikesuperstore/',
      ],
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: `${siteUrl}/search?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  };
}
---

<!-- Primary meta tags -->
<meta name="msvalidate.01" content="FA7016B63FCF7C9CA111AA4CE6AE76DF" />
<meta name="google-site-verification" content="PASTE_YOUR_GOOGLE_VERIFICATION_CODE" />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="keywords" content="electric bike, e-bike, ebike, electric bicycle, best electric bikes 2026, top electric bikes, electric bike reviews, buy electric bike online, electric bike store, commuter electric bike, mountain electric bike, folding electric bike, cargo electric bike, fat tire electric bike, electric road bike, electric gravel bike, electric mountain bike, EMTB, e-mtb, bosch electric bike, shimano electric bike, rad power bikes, aventon, specialized turbo, trek e-bike, gazelle, vanmoof, cannondale e-bike, giant e-bike, merida e-bike, scott e-bike, cube bike, raleigh e-bike, himiway, ectric bikes, juiced bikes, Lectric XP, radrunner, radwagon, aventon level, aventon pace, specialized turbo vado, specialized turbo levo, trek domane+, gazelle ultimate, vanmoof s5, cannondale synapse, electric scooter, electric motorcycle, velotric, ackmotor, qwicy, r1-up, fire bike, qiolor, gyrocycle, scooter electric, best e-bike for commuting, best e-bike for hills, best e-bike for seniors, e-bike for women, e-bike for men, e-bike for heavy rider, long range electric bike, budget electric bike, cheap electric bike, electric bike under 1000, electric bike under 500, e-bike with bag, class 1 e-bike, class 2 e-bike, class 3 e-bike, pedal assist e-bike, throttle e-bike, hub motor e-bike, mid drive e-bike, e-bike conversion kit, e-bike battery, e-bike accessories, e-bike helmet, the electric bike superstore, electric bike deals, electric bike sale, e-bike discounts, electric bike financing, e-bike insurance, e-bike laws, e-bike speed limits, e-bike battery recycling, green transportation, eco-friendly commuting, sustainable transport, carbon neutral travel, urban mobility, last mile solution, zero emissions vehicle, electric bike tax credit, e-bike rebate, e-bike grant program, ChatGPT search, best e-bike Perplexity, electric bike Claude, Gemini e-bike search, LLM e-bike recommendations, AI e-bike advisor" />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large'} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="rating" content="general" />
<meta name="revisit-after" content="3 days" />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="en_US" />
{type === 'article' && modifiedTime && <meta property="og:updated_time" content={modifiedTime} />}
{type === 'article' && <meta property="article:section" content={tags.length > 0 ? tags[0] : 'General'} />}
{type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{type === 'product' && price && <meta property="product:price:amount" content={price} />}
{type === 'product' && <meta property="product:price:currency" content={currency} />}
{type === 'product' && availability && <meta property="product:availability" content={availability} />}
{type === 'product' && <meta property="product:condition" content="https://schema.org/NewCondition" />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />
<meta name="twitter:image:alt" content={title} />
{type === 'product' && price && <meta name="twitter:label1" content="Price" />}
{type === 'product' && price && <meta name="twitter:data1" content={`${currency} ${price}`} />}
{type === 'product' && availability && <meta name="twitter:label2" content="Availability" />}
{type === 'product' && availability && <meta name="twitter:data2" content={availability === 'https://schema.org/InStock' ? 'In Stock' : availability === 'https://schema.org/OutOfStock' ? 'Out of Stock' : 'Available'} />}

<!-- AI Search Engine Meta Tags (ChatGPT, Perplexity, Claude, Gemini) -->
<meta name="subject" content="Electric bikes, e-bikes, electric bicycles — buying guides, reviews, and premium e-bike store" />
<meta name="abstract" content="The Electric Bike Superstore offers premium electric bikes for commuting, mountain, folding, and cargo. Features expert buying guides, reviews, and curated e-bike selection with free shipping." />
<meta name="topic" content="Electric Bikes, E-Bikes, Electric Cycling, Green Transportation, Urban Mobility" />
<meta name="classification" content="Shopping, Sports & Recreation, Technology, Green Transportation" />
<meta name="category" content="Electric Bikes & Bicycles" />
<meta name="summary" content="Premium electric bike store with commuter, mountain, folding, cargo, and fat tire e-bikes. Expert guides, honest reviews, free shipping over $75, 30-day returns." />
<meta name="target" content="cyclists, commuters, outdoor enthusiasts, eco-conscious consumers, e-bike buyers, urban riders, seniors, fitness riders, cargo bike families" />
<meta name="audience" content="all" />
<meta name="coverage" content="United States" />

<!-- Additional SEO -->
<meta name="theme-color" content="#2d8a4e" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={siteName} />
<meta name="format-detection" content="telephone=no" />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title={`${siteName} — Blog RSS Feed`} href="/rss.xml" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData, null, 2)} />

<!-- Preconnect optimization -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://fonts.googleapis.com" />

<!-- Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
